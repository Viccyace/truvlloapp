{
  "cleanUrls": false,
  "routes": [
    { "src": "/sw.js",                "dest": "/sw.js" },
    { "src": "/manifest.webmanifest", "dest": "/manifest.webmanifest" },
    { "src": "/robots.txt",           "dest": "/robots.txt" },
    { "src": "/sitemap.xml",          "dest": "/sitemap.xml" },
    { "src": "/favicon.ico",          "dest": "/favicon.ico" },
    { "src": "/favicon.svg",          "dest": "/favicon.svg" },
    { "src": "/favicon.png",          "dest": "/favicon.png" },
    { "src": "/apple-touch-icon.png", "dest": "/apple-touch-icon.png" },
    { "src": "/og-image.png",         "dest": "/og-image.png" },
    { "src": "/icons/(.*)",           "dest": "/icons/$1" },
    { "src": "/assets/(.*)",          "dest": "/assets/$1" },
    { "src": "/api/(.*)",             "dest": "/api/$1" },
    {
      "src": "/(.*)",
      "dest": "/index.html",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "X-Frame-Options": "DENY",
        "Referrer-Policy": "strict-origin-when-cross-origin"
      }
    }
  ]
}
